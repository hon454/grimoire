<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{TITLE}}</title>
  <style>
    :root {
      color-scheme: light dark;
      --paper: #f4f0e7;
      --ink: #1c2621;
      --muted: #5f6a63;
      --line: #c8c4b9;
      --panel: #fffdf7;
      --accent: #145c43;
      --accent-soft: #dcebe2;
      --warn: #8c451b;
      --warn-soft: #f7e5d7;
      --code: #17211d;
      --code-ink: #edf7f0;
    }
    * { box-sizing: border-box; }
    html { scroll-behavior: auto; }
    body {
      margin: 0;
      background: var(--paper);
      color: var(--ink);
      font-family: ui-serif, Georgia, Cambria, "Times New Roman", serif;
      line-height: 1.6;
    }
    body > header, body > nav, body > main, body > footer {
      width: min(1120px, calc(100% - 2rem));
      margin-inline: auto;
    }
    .snapshot {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(260px, 360px);
      gap: 2rem;
      align-items: end;
      padding: 4rem 0 2rem;
      border-bottom: 3px solid var(--ink);
    }
    .eyebrow, .pending-panel span, .item-number {
      margin: 0;
      color: var(--accent);
      font: 700 .75rem/1.2 ui-monospace, SFMono-Regular, Consolas, monospace;
      letter-spacing: .1em;
      text-transform: uppercase;
    }
    h1 { margin: .35rem 0; font-size: clamp(2rem, 5vw, 4.4rem); line-height: 1; }
    h2, h3, h4 { line-height: 1.25; }
    .snapshot-line { margin: 1rem 0 0; color: var(--muted); }
    .pending-panel {
      display: grid;
      gap: .55rem;
      padding: 1.25rem;
      border: 1px solid var(--accent);
      background: var(--accent-soft);
    }
    nav { padding: 2rem 0; }
    nav h2 { margin: 0 0 .75rem; }
    nav ol { margin: 0; padding-left: 1.4rem; columns: 2; column-gap: 3rem; }
    nav li { break-inside: avoid; padding: .25rem 0; }
    nav a { color: var(--accent); text-underline-offset: .2em; }
    nav span { color: var(--muted); font: .75rem ui-monospace, SFMono-Regular, Consolas, monospace; }
    main { display: grid; gap: 1rem; padding-bottom: 4rem; }
    details { border: 1px solid var(--line); background: var(--panel); scroll-margin-top: 1rem; }
    details[open] { border-color: var(--ink); box-shadow: 0 12px 30px rgb(28 38 33 / 8%); }
    summary {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      align-items: center;
      padding: 1.2rem 1.4rem;
      cursor: pointer;
      font-size: 1.08rem;
      font-weight: 700;
    }
    summary:focus-visible, a:focus-visible { outline: 3px solid #d57a35; outline-offset: 3px; }
    .summary-main, .summary-badges, .choice-title { display: flex; gap: .7rem; align-items: center; flex-wrap: wrap; }
    .item-body { padding: 0 1.4rem 1.6rem; }
    .item-meta {
      display: flex;
      flex-wrap: wrap;
      gap: .6rem 1.2rem;
      padding: .9rem 0 1.2rem;
      color: var(--muted);
      border-top: 1px solid var(--line);
      font: .78rem/1.5 ui-monospace, SFMono-Regular, Consolas, monospace;
    }
    section { padding: 1.25rem 0; border-top: 1px solid var(--line); }
    section h3 { margin: 0 0 .8rem; font-size: 1.1rem; }
    section h4 { margin: 1rem 0 .35rem; }
    section p { max-width: 80ch; }
    .badge {
      display: inline-block;
      padding: .18rem .5rem;
      border-radius: 999px;
      font: 700 .68rem/1.4 ui-monospace, SFMono-Regular, Consolas, monospace;
      letter-spacing: .02em;
    }
    .pending, .recommended { color: #073d2a; background: #bde2cd; }
    .outdated { color: #66300f; background: var(--warn-soft); }
    .review-text, .code pre {
      overflow: auto;
      white-space: pre-wrap;
      overflow-wrap: anywhere;
      tab-size: 4;
    }
    .review-text { padding: 1rem; background: #eee9de; color: #1c2621; border-left: 4px solid var(--line); }
    .code { margin: 1rem 0; }
    .code figcaption { padding: .55rem .8rem; background: #2c3a33; color: #dfe9e3; font: .75rem ui-monospace, SFMono-Regular, Consolas, monospace; }
    .code pre { margin: 0; padding: 1rem; background: var(--code); color: var(--code-ink); }
    code, .mono-wrap { font-family: ui-monospace, SFMono-Regular, Consolas, monospace; }
    .mono-wrap { overflow-wrap: anywhere; }
    .plain-list { margin: .4rem 0; padding-left: 1.25rem; }
    .empty { color: var(--muted); font-style: italic; }
    .empty-state { padding: 3rem; text-align: center; border: 1px dashed var(--line); }
    .example { padding: .7rem 1rem; border-left: 4px solid var(--accent); background: var(--accent-soft); }
    .example + .example { margin-top: .75rem; }
    dl { margin: .4rem 0; }
    dt { font-weight: 700; }
    dd { margin: 0 0 .55rem; }
    .alternatives { display: grid; gap: .8rem; padding-left: 1.5rem; }
    .alternatives li { padding: .7rem 1rem; border: 1px solid var(--line); }
    .alternatives p { margin: .4rem 0 0; }
    .tradeoff { color: var(--muted); }
    .envelope { display: grid; grid-template-columns: minmax(130px, .25fr) minmax(0, 1fr); gap: .7rem 1.2rem; }
    .envelope dd { margin: 0; }
    .status-callout { padding: .8rem 1rem; border-left: 4px solid var(--accent); background: var(--accent-soft); }
    .status-callout.stale { border-color: var(--warn); background: var(--warn-soft); }
    .status-callout p { margin: .25rem 0 0; }
    .history { color: var(--muted); }
    .recommendation { border-left: 4px solid var(--accent); padding-left: 1rem; }
    .decision-question { border: 2px solid var(--accent); margin-top: .5rem; padding: 1.2rem; background: var(--accent-soft); }
    footer { padding: 1.4rem 0 3rem; color: var(--muted); border-top: 1px solid var(--line); }
    @media (max-width: 760px) {
      .snapshot { grid-template-columns: 1fr; padding-top: 2rem; }
      nav ol { columns: 1; }
      summary { align-items: flex-start; flex-direction: column; }
      .envelope { grid-template-columns: 1fr; }
      .envelope dt { margin-top: .5rem; }
    }
    @media (prefers-contrast: more) {
      :root { --line: #5a625d; }
      details, .pending-panel, .decision-question { border-width: 2px; }
    }
    @media (prefers-color-scheme: dark) {
      :root {
        --paper: #111713;
        --ink: #eef5f0;
        --muted: #aebbb3;
        --line: #536159;
        --panel: #19221d;
        --accent: #88d2ab;
        --accent-soft: #20392c;
        --warn: #ef9b62;
        --warn-soft: #3b291e;
      }
      .review-text { background: #252e29; color: #eef5f0; }
      .pending, .recommended { color: #dff6e8; background: #275f43; }
      .outdated { color: #ffe8d5; background: #683816; }
    }
  </style>
</head>
<body>
{{BODY}}
</body>
</html>
